rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Проверка прав администратора через UID документа 'Aboba'
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/Aboba) &&
        get(/databases/$(database)/documents/users/Aboba).data.uid == request.auth.uid;
    }

    match /users/{nickname} {
      allow read: if true;
      
      // Создавать может любой, но один раз (UID прописывается при создании)
      allow create: if request.auth != null;
      
      // Обновлять может только владелец UID или админ
      // Обычные пользователи не могут:
      // 1. Менять критические поля (блокируется в diff)
      // 2. Уходить в минус (критично для защиты от абуза в нескольких вкладках)
      allow update: if request.auth != null && (resource.data.uid == request.auth.uid || isAdmin()) && (
        isAdmin() || (
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['isBanned', 'luck', 'email', 'uid', 'nickname']) &&
          request.resource.data.balance >= 0
        )
      );
      
      allow delete: if isAdmin();
    }

    match /games/{gameId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
