rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Проверка прав администратора через UID документа 'Aboba'
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/Aboba) &&
        get(/databases/$(database)/documents/users/Aboba).data.uid == request.auth.uid;
    }

    match /users/{nickname} {
      allow read: if true;
      allow create: if request.auth != null;
      
      // Разрешаем обновление, если пользователь авторизован
      allow update: if request.auth != null && (
        isAdmin() || (
          // Убеждаемся, что меняется только баланс и другие некритичные поля
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['isBanned', 'luck', 'email', 'uid', 'nickname']) &&
          request.resource.data.balance >= 0
        )
      );
      
      allow delete: if isAdmin();
    }

    match /games/{gameId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
